rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    match /subscriptions/{subId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() &&
        resource.data.ownerId == request.auth.uid;
    }

    match /subscriptions/{subId}/messages/{msgId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /participations/{partId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/subscriptions/$(resource.data.subscriptionId)).data.ownerId == request.auth.uid);
      allow delete: if false;
    }

    match /payments/{payId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /invoices/{invId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /notifications/{nId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /trustEvents/{eId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
